# Lead capture → CRM
# When set, all lead/enterprise form submissions POST directly to this URL
# (GoHighLevel Inbound Webhook, Zapier Catch Hook, Make.com webhook, n8n, etc.)
# so the forms work on a static host with no backend.
# Leave unset to use the built-in Express /api backend (Twenty CRM sync).
VITE_LEADS_WEBHOOK_URL=

# --- Full-stack backend only (server/) ---
# STRIPE_SECRET_KEY=
# TWENTY_API_KEY=
